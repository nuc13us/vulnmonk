# GitHub OAuth Configuration
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:3000/integrations

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/integrations

# CORS_ORIGINS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Database Path (optional, defaults to vulnmonk.db in project root)
# DATABASE_PATH=/path/to/vulnmonk.db
